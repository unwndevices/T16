{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "T16 Configuration",
  "type": "object",
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "version": { "type": "integer" },
        "mode": { "type": "integer" },
        "sensitivity": { "type": "integer" },
        "brightness": { "type": "integer" },
        "midi_trs": { "type": "integer" },
        "trs_type": { "type": "integer" },
        "passthrough": { "type": "integer" },
        "midi_ble": { "type": "integer" },
        "custom_scale1": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 16,
          "maxItems": 16
        },
        "custom_scale2": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 16,
          "maxItems": 16
        }
      },
      "required": ["version", "mode", "sensitivity", "brightness", "midi_trs", "trs_type", "passthrough", "midi_ble"]
    },
    "banks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pal": { "type": "integer" },
          "ch": { "type": "integer" },
          "scale": { "type": "integer" },
          "oct": { "type": "integer" },
          "note": { "type": "integer" },
          "vel": { "type": "integer" },
          "at": { "type": "integer" },
          "flip_x": { "type": "integer" },
          "flip_y": { "type": "integer" },
          "koala_mode": { "type": "integer" },
          "chs": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "ids": {
            "type": "array",
            "items": { "type": "integer" }
          }
        },
        "required": ["pal", "ch", "scale", "oct", "note", "vel", "at", "flip_x", "flip_y", "koala_mode"]
      }
    }
  },
  "required": ["global", "banks"]
}
